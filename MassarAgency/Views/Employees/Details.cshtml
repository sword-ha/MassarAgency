@model EmployeeDto
@{
    ViewData["Title"] = "Employee Profile";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-outline-secondary me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div>
                <h4 class="mb-0">Employee Profile</h4>
                <p class="text-muted mb-0 small">Detailed employee information</p>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-burgundy text-white d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-white text-burgundy d-flex align-items-center justify-content-center"
                         style="width: 50px; height: 50px; font-size: 1.2rem; font-weight: 700;">
                        @Model.FullName[0]
                    </div>
                    <div>
                        <h5 class="mb-0">@Model.FullName</h5>
                        <small class="opacity-75">@Model.JobTitle</small>
                    </div>
                </div>
                <div>
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactive</span>
                    }
                </div>
            </div>
            <div class="card-body p-4">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label text-muted small mb-0">Full Name</label>
                            <p class="fw-semibold mb-0">@Model.FullName</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label text-muted small mb-0">Email</label>
                            <p class="fw-semibold mb-0">@Model.Email</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label text-muted small mb-0">Phone</label>
                            <p class="fw-semibold mb-0">@Model.Phone</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label text-muted small mb-0">Department</label>
                            <p class="fw-semibold mb-0"><span class="badge bg-light text-dark border">@Model.DepartmentName</span></p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label text-muted small mb-0">Base Salary</label>
                            <p class="fw-semibold mb-0 text-burgundy">@Model.BaseSalary.ToString("N2") EGP</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label text-muted small mb-0">Hire Date</label>
                            <p class="fw-semibold mb-0">@Model.HireDate.ToString("MMMM dd, yyyy")</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer d-flex justify-content-between">
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-pencil me-1"></i> Edit
                    </a>
                    <a asp-controller="Attendance" asp-action="EmployeeHistory" asp-route-id="@Model.Id" class="btn btn-outline-info btn-sm">
                        <i class="bi bi-calendar-check me-1"></i> Attendance History
                    </a>
                    <a asp-controller="Reports" asp-action="EmployeeDeduction" asp-route-id="@Model.Id" class="btn btn-outline-warning btn-sm">
                        <i class="bi bi-cash me-1"></i> Deduction Details
                    </a>
                </div>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Are you sure you want to delete this employee?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger btn-sm">
                        <i class="bi bi-trash me-1"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
