@model LoginDto
@{
    ViewData["Title"] = "Login";
    Layout = "_LoginLayout";
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card login-card mx-auto">
            <div class="login-header">
                <img style="width:300px" src="~/images/removed backg massar.png" />
@*                 <h3 class="mt-2 mb-0">Masar</h3> *@
                <small class="opacity-75">Employee Attendance System</small>
            </div>
            <div class="card-body p-4">
                <h5 class="text-center mb-4">Sign In</h5>

                <form asp-action="Login" method="post">
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label">
                            <i class="bi bi-person me-1"></i> Username or Email
                        </label>
                        <input asp-for="Username" class="form-control" placeholder="Enter username or email" autofocus />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">
                            <i class="bi bi-lock me-1"></i> Password
                        </label>
                        <input asp-for="Password" class="form-control" placeholder="Enter password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">Remember me</label>
                    </div>

                    <button type="submit" class="btn btn-burgundy w-100 py-2">
                        <i class="bi bi-box-arrow-in-right me-1"></i> Sign In
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
