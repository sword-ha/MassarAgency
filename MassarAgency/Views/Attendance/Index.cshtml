@model BulkAttendanceDto
@{
    ViewData["Title"] = "Attendance Tracking";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Attendance Tracking</h4>
        <p class="text-muted mb-0 small">Record daily attendance for all employees</p>
    </div>
</div>

<!-- Date Picker -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Select Date</label>
                <input type="date" name="date" value="@Model.Date.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-burgundy">
                    <i class="bi bi-calendar-check me-1"></i> Load Attendance
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Bulk Attendance Form -->
@if (Model.Entries.Any())
{
    <form asp-action="SaveBulk" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Date" value="@Model.Date.ToString("yyyy-MM-dd")" />

        <div class="card">
            <div class="card-header bg-burgundy text-white d-flex justify-content-between align-items-center">
                <span><i class="bi bi-calendar-check me-2"></i> Attendance for @Model.Date.ToString("dddd, MMMM dd, yyyy")</span>
                <span class="badge bg-white text-burgundy">@Model.Entries.Count Employees</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-masar table-hover mb-0">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Employee</th>
                                <th>Department</th>
                                <th>Status</th>
                                <th>Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.Entries.Count; i++)
                            {
                                <tr>
                                    <td>@(i + 1)</td>
                                    <td>
                                        <strong>@Model.Entries[i].EmployeeName</strong>
                                        <input type="hidden" name="Entries[@i].EmployeeId" value="@Model.Entries[i].EmployeeId" />
                                        <input type="hidden" name="Entries[@i].EmployeeName" value="@Model.Entries[i].EmployeeName" />
                                        <input type="hidden" name="Entries[@i].DepartmentName" value="@Model.Entries[i].DepartmentName" />
                                    </td>
                                    <td><span class="badge bg-light text-dark border">@Model.Entries[i].DepartmentName</span></td>
                                    <td>
                                        <select name="Entries[@i].Status" class="form-select form-select-sm" style="width: 140px;">
                                            @foreach (var status in Enum.GetValues<AttendanceStatus>())
                                            {
                                                <option value="@((int)status)"
                                                        selected="@(Model.Entries[i].Status == status)">
                                                    @status.ToString()
                                                </option>
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        <input type="text" name="Entries[@i].Notes" value="@Model.Entries[i].Notes"
                                               class="form-control form-control-sm" placeholder="Optional notes..." style="min-width: 180px;" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer d-flex justify-content-end">
                <button type="submit" class="btn btn-burgundy">
                    <i class="bi bi-check-lg me-1"></i> Save All Attendance
                </button>
            </div>
        </div>
    </form>
}
else
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-calendar-x" style="font-size: 3rem; color: #ccc;"></i>
            <p class="text-muted mt-2">No active employees found to record attendance.</p>
        </div>
    </div>
}
